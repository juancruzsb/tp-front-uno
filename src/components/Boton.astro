---
    const text = Astro.props.text || "Button";
---

<button>{text}</button>

<style>
    button {
        padding: 2% 10%;
        background-color: #2b3641;
        color: white;
        border: none;
        border-radius: 4%;
        font-size: 0.875rem;
        font-family: "Inter", sans-serif;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    button:hover {
        background-color: #3c4a5a;
    }
</style>